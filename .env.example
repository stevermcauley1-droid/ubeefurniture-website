# Shopify Storefront API — get token from Headless → Storefront API → Manage → Access tokens
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Prefer SHOPIFY_STOREFRONT_ACCESS_TOKEN; fallback key SHOPIFY_STOREFRONT_TOKEN also supported
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional: Admin API fallback (catalog only, no cart/checkout)
# SHOPIFY_ADMIN_ACCESS_TOKEN=
# SHOPIFY_DATA_MODE=admin

# Site URL for sitemap and canonicals
NEXT_PUBLIC_SITE_URL=https://www.ubeefurniture.co.uk

# Supabase (catalogue leads + health check)
# Project ref nlrkpsdxekgklvcqumhm → URL below. Get keys from Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://nlrkpsdxekgklvcqumhm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (server-only; NEVER expose to client) — for catalogue-leads insert
SUPABASE_SERVICE_ROLE_KEY=

# Admin dashboard token for /admin/leads (querystring token)
ADMIN_DASH_TOKEN=

# GA4 (Phase 6) — Measurement ID for e-commerce events
# Use placeholder G-XXXXXXXXXX if not yet configured (script won't load, no console errors)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Alias: NEXT_PUBLIC_GA_ID= also supported
# GA4_API_SECRET= (for purchase tracking via Measurement Protocol — get from GA4 Admin → Data Streams)

# Heatmaps & Session Replay (Phase 6) — Optional
# NEXT_PUBLIC_HOTJAR_ID=
# NEXT_PUBLIC_CLARITY_ID=

# Shopify Webhook (Phase 6) — For purchase event tracking
# SHOPIFY_WEBHOOK_SECRET= (set in Shopify webhook settings, verify in route handler)