{
  "name": "ubeefurniture-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rimraf .next && rimraf node_modules/.cache && next dev",
    "postinstall": "prisma generate",
    "build": "next build",
    "lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=./docs/lighthouse-mobile-report.json --preset=perf --form-factor=mobile --chrome-flags=\"--headless\"",
    "start": "next start",
    "lint": "next lint",
    "shopify:smoke": "node scripts/shopify-smoke-test.mjs",
    "shopify:test-connection": "node scripts/test-shopify-connection.mjs",
    "heartlands:scrape": "node scripts/heartlands-scraper.mjs",
    "heartlands:shopify": "node scripts/heartlands-scraper.mjs --shopify-json --out=data/heartlands/shopify-products.json",
    "heartlands:shopify:exhaustive": "node scripts/heartlands-scraper.mjs --shopify-json --out=data/heartlands/shopify-products.json --max-pages=500",
    "heartlands:shopify:sample": "node scripts/heartlands-scraper.mjs --shopify-json --out=data/heartlands/shopify-products.json --category=https://www.heartlandsfurniture.co.uk/product-category/dining/dining-tables/ --max-pages=5 --limit=10",
    "heartlands:import:dry": "node scripts/heartlands-import-to-shopify.mjs --dry-run --limit=10 --file=scripts/heartlands/fixtures/example-shopify-products.json",
    "heartlands:import": "node scripts/heartlands-import-to-shopify.mjs --apply --publish",
    "heartlands:ensure-storefront": "node scripts/heartlands/ensure-heartlands-storefront.mjs",
    "beehive:fetch": "node scripts/beehive-scraper.mjs",
    "beehive:import:dry": "node scripts/heartlands-import-to-shopify.mjs --dry-run --file=data/beehive/shopify-products.json",
    "beehive:import": "node scripts/heartlands-import-to-shopify.mjs --apply --publish --file=data/beehive/shopify-products.json",
    "beehive:assign-collections": "node scripts/beehive/assign-beehive-collections.mjs",
    "beehive:assign-collections:dry": "node scripts/beehive/assign-beehive-collections.mjs --dry-run",
    "beehive:ensure-storefront": "node scripts/beehive/ensure-beehive-storefront.mjs",
    "beehive:report-missing-images": "node scripts/beehive/report-missing-images.mjs",
    "wholesalebeds:fetch": "node scripts/wholesalebeds-scraper.mjs --out=data/wholesalebeds/shopify-products.json",
    "wholesalebeds:import:dry": "node scripts/heartlands-import-to-shopify.mjs --dry-run --file=data/wholesalebeds/shopify-products.json",
    "wholesalebeds:import": "node scripts/heartlands-import-to-shopify.mjs --apply --publish --file=data/wholesalebeds/shopify-products.json",
    "wholesalebeds:assign-collections": "node scripts/wholesalebeds/assign-wholesalebeds-collections.mjs",
    "wholesalebeds:assign-collections:dry": "node scripts/wholesalebeds/assign-wholesalebeds-collections.mjs --dry-run",
    "wholesalebeds:ensure-storefront": "node scripts/wholesalebeds/ensure-wholesalebeds-storefront.mjs",
    "seconique:fetch": "node scripts/seconique-scraper.mjs --out=data/seconique/shopify-products.json",
    "seconique:catalogues": "node scripts/seconique/download-catalogues.mjs",
    "seconique:import:dry": "node scripts/heartlands-import-to-shopify.mjs --dry-run --file=data/seconique/shopify-products.json",
    "seconique:import": "node scripts/heartlands-import-to-shopify.mjs --apply --publish --file=data/seconique/shopify-products.json",
    "shopify:test": "node scripts/shopify/storefront-test.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:local": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "ftg:import:details": "tsx scripts/ftg/import-ftg-details.ts",
    "ftg:import:price": "tsx scripts/ftg/import-ftg-price.ts",
    "ftg:sync:all": "tsx scripts/ftg/import-ftg-details.ts && tsx scripts/ftg/import-ftg-price.ts",
    "ftg:sync:shopify": "tsx scripts/ftg/sync-ftg-to-shopify.ts",
    "ftg:normalize": "node scripts/import/ftg/normalize-ftg.mjs",
    "ftg:build-shopify": "node scripts/import/ftg/build-shopify-products.mjs",
    "ftg:import:dry": "node scripts/import/ftg/import-to-shopify.mjs --dry-run --limit=10",
    "ftg:import": "node scripts/import/ftg/import-to-shopify.mjs --apply --limit=10",
    "ftg:import:sku": "node scripts/import/ftg/import-to-shopify.mjs --apply --limit=1 --publish --sync-price",
    "ftg:sync:prices:30pct": "npx tsx scripts/ftg/update-shopify-variant-prices-from-ftg.ts --limit=50",
    "collections:create": "tsx scripts/create-collections.ts",
    "collections:verify": "tsx scripts/verify-collections.ts",
    "shopify:test-auth": "tsx scripts/test-shopify-auth.ts",
    "ftg:import:dropbox": "node scripts/import-ftg-products.js",
    "shopify:admin-token": "node scripts/shopify/fetch-admin-token-client-credentials.mjs",
    "ftg:import:retry-failed": "node scripts/import/ftg/retry-failed-imports.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "csv-parse": "^6.1.0",
    "next": "^14.2.0",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.24",
    "dotenv": "^16.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.5.6",
    "prisma": "^7.4.0",
    "rimraf": "^5.0.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
